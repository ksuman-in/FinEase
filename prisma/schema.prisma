generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GroupRole {
  OWNER
  MEMBER
}

enum UserRole {
  MEMBER
  BORROWER
  ADMIN
}

enum LoanStatus {
  ACTIVE
  PAID
  DEFAULTED
  CLOSED
  REQUEST
  CANCELLED
}

enum TransactionType {
  CONTRIB
  INT_PAID
  PRIN_REPAY
  NEW_LOAN
  TOP_UP
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  isVerified   Boolean @default(false)
  isSuperAdmin Boolean @default(false)

  phoneNumber String? @unique

  role UserRole @default(MEMBER)

  address          String?
  idNumber         String? @unique // e.g., Aadhar, PAN, or DL
  emergencyContact String?

  // Relations
  memberships  Membership[]
  loans        MemberLoan[]
  transactions MemberTransaction[]
  sessions     Session[]
  accounts     Account[]

  @@map("user")
}

model Group {
  id           String @id @default(cuid())
  name         String @default("Power 10 Finance")
  maxMembers   Int    @default(10)
  interestRate Float  @default(1.0)
  strategy     String @default("Power 5 Rotation")

  // Relations
  memberships    Membership[]
  allowedEmails  AllowedUser[]
  loans          MemberLoan[]
  transactions   MemberTransaction[]
  monthlyReports MonthlyReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Membership {
  id      String    @id @default(cuid())
  role    GroupRole @default(MEMBER)
  userId  String
  groupId String

  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id])
  group Group @relation(fields: [groupId], references: [id])

  @@unique([userId, groupId])
}

model MemberLoan {
  id           String     @id @default(uuid())
  userId       String
  groupId      String
  amount       Float
  interestRate Float      @default(1.0)
  status       LoanStatus @default(ACTIVE)
  issuedAt     DateTime   @default(now())
  description  String?

  // Relations
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  group        Group               @relation(fields: [groupId], references: [id])
  transactions MemberTransaction[]

  @@index([userId])
}

model MemberTransaction {
  id          String          @id @default(uuid())
  userId      String
  loanId      String?
  groupId     String
  amount      Float
  type        TransactionType
  date        DateTime        @default(now())
  description String?

  // Relations
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  loan  MemberLoan? @relation(fields: [loanId], references: [id])
  group Group       @relation(fields: [groupId], references: [id])

  @@index([userId, date])
  @@index([type])
}

model GlobalSettings {
  id Int @id @default(autoincrement())

  monthlyContribution Float @default(1000)

  memberInterestRate Float @default(12)
  marketInterestRate Float @default(18)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlyReport {
  id         String   @id @default(uuid())
  reportDate DateTime @unique

  // Monthly Flow (In/Out during this month)
  interestCollected  Float @default(0) // Profit
  loansDisbursed     Float @default(0) // New money out
  principalRecovered Float @default(0) // Debt returned

  // Group Status (Snapshots at month-end)
  totalInterest    Float @default(0)
  totalMembersFund Float @default(0) // Total savings
  totalDistributed Float @default(0) // Outstanding Principal
  cashInHand       Float @default(0) // Liquid cash
  totalGroupValue  Float @default(0) // Cash + Distributed

  groupId String
  group   Group  @relation(fields: [groupId], references: [id])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model AllowedUser {
  id          String   @id @default(cuid())
  email       String   @unique
  phoneNumber String   @unique // Added unique phone number
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id])
  token       String   @unique @default(uuid())
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([email, phoneNumber]) // Speeds up lookup during registration
}
