generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum GroupRole {
  OWNER
  MEMBER
  BORROWER
}

enum LoanStatus {
  ACTIVE
  PAID
  DEFAULTED
  CLOSED
  REQUEST
  CANCELLED
}

enum TransactionType {
  CONTRIB
  INT_PAID
  PRIN_REPAY
  NEW_LOAN
  TOP_UP
}

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  isVerified   Boolean @default(false)
  isSuperAdmin Boolean @default(false)

  phoneNumber String? @unique

  role GroupRole @default(MEMBER)

  address          String?
  idNumber         String? @unique // e.g., Aadhar, PAN, or DL
  emergencyContact String?

  // Relations
  memberships  Membership[]
  loans        MemberLoan[]
  transactions MemberTransaction[]
  sessions     Session[]
  accounts     Account[]

  @@map("user")
}

model Group {
  id           String @id @default(cuid())
  name         String @default("Power 10 Finance")
  maxMembers   Int    @default(10)
  interestRate Float  @default(1.0)
  strategy     String @default("Power 5 Rotation")

  // Relations
  memberships    Membership[]
  allowedEmails  AllowedUser[]
  loans          MemberLoan[]
  transactions   MemberTransaction[]
  monthlyReports MonthlyReport[]

  config GroupConfig?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Membership {
  id      String    @id @default(cuid())
  role    GroupRole @default(MEMBER)
  userId  String
  groupId String

  loan       Loan?
  customRate Float?

  createdAt DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id])
  group        Group         @relation(fields: [groupId], references: [id])
  loanArchives LoanArchive[]

  @@unique([userId, groupId])
}

model MemberLoan {
  id           String     @id @default(uuid())
  userId       String
  groupId      String
  amount       Float
  interestRate Float      @default(1.0)
  status       LoanStatus @default(ACTIVE)
  issuedAt     DateTime   @default(now())
  description  String?

  // Relations
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  group        Group               @relation(fields: [groupId], references: [id])
  transactions MemberTransaction[]

  @@index([userId])
}

model MemberTransaction {
  id          String          @id @default(uuid())
  userId      String
  loanId      String?
  groupId     String
  amount      Float
  type        TransactionType
  date        DateTime        @default(now())
  description String?

  // Relations
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  loan  MemberLoan? @relation(fields: [loanId], references: [id])
  group Group       @relation(fields: [groupId], references: [id])

  @@index([userId, date])
  @@index([type])
}

model GroupConfig {
  id      String @id @default(cuid())
  groupId String @unique
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  monthlyContribution  Float @default(1000)
  minPrincipalPayment  Float @default(10000)
  // Interest Rate Settings
  memberInterestRate   Float @default(12)
  borrowerInterestRate Float @default(18)

  interestStartDay  Int @default(1)
  interestEndDay    Int @default(5)
  principalStartDay Int @default(1)
  principalEndDay   Int @default(10)

  updatedAt DateTime @updatedAt
}

model GlobalSettings {
  id Int @id @default(autoincrement())

  monthlyContribution Float @default(1000)

  memberInterestRate Float @default(12)
  marketInterestRate Float @default(18)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlyReport {
  id         String   @id @default(uuid())
  reportDate DateTime @unique

  // Monthly Flow (In/Out during this month)
  interestCollected  Float @default(0) // Profit
  loansDisbursed     Float @default(0) // New money out
  principalRecovered Float @default(0) // Debt returned

  // Group Status (Snapshots at month-end)
  totalInterest    Float @default(0)
  totalMembersFund Float @default(0) // Total savings
  totalDistributed Float @default(0) // Outstanding Principal
  cashInHand       Float @default(0) // Liquid cash
  totalGroupValue  Float @default(0) // Cash + Distributed

  groupId String
  group   Group  @relation(fields: [groupId], references: [id])
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model AllowedUser {
  id          String    @id @default(cuid())
  email       String    @unique
  phoneNumber String    @unique
  role        GroupRole @default(MEMBER)
  groupId     String
  group       Group     @relation(fields: [groupId], references: [id])
  token       String    @unique @default(uuid())
  createdAt   DateTime  @default(now())
  expiresAt   DateTime

  @@unique([email, groupId])
  @@unique([phoneNumber, groupId])
}

// Represents the financial agreement between the Vault and a Member
model Loan {
  id String @id @default(cuid())

  // Relations
  membershipId String     @unique
  membership   Membership @relation(fields: [membershipId], references: [id])

  // Financial Core
  principalAmount    Float // The initial capital assigned
  remainingPrincipal Float // Current outstanding amount
  interestRate       Float // Unique ROI (e.g., 18.0) assigned by Owner
  tenureMonths       Int // Total duration (6-60 months)

  // Status & Lifecycle
  status    LoanStatus @default(ACTIVE)
  startDate DateTime   @default(now())
  endDate   DateTime?

  // Repayment Tracking
  repayments Repayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([membershipId])
}

model LoanArchive {
  id                 String     @id @default(cuid())
  membershipId       String
  membership         Membership @relation(fields: [membershipId], references: [id]) // Add this relation
  principalAmount    Int
  interestRate       Float
  tenureMonths       Int
  totalInterestPaid  Int
  totalPrincipalPaid Int
  startDate          DateTime
  endDate            DateTime   @default(now())
}

// Tracking individual EMIs and contributions
model Repayment {
  id     String @id @default(cuid())
  loanId String
  loan   Loan   @relation(fields: [loanId], references: [id], onDelete: Cascade)

  amountPaid    Float // Total EMI amount
  principalPaid Float // Portion reducing the principal
  interestPaid  Float // Portion contributing to group yield

  paymentDate DateTime        @default(now())
  status      RepaymentStatus @default(COMPLETED)

  // Metadata for the 25th—30th window enforcement
  billingMonth Int // 1-12
  billingYear  Int

  createdAt DateTime @default(now())

  @@index([loanId])
}

enum RepaymentStatus {
  PENDING
  COMPLETED
  OVERDUE
}
